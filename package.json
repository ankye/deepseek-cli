{
  "name": "deepseek-cli-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/apps/*",
    "src/packages/*"
  ],
  "scripts": {
    "scaffold": "node scripts/scaffold-workspace.mjs",
    "build:cli": "npm run build --workspace deepseek-agent-cli",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node scripts/lint.mjs",
    "test": "tsx --test \"src/**/*.test.ts\" \"tests/**/*.test.ts\"",
    "test:contracts": "tsx --test \"tests/contracts/**/*.test.ts\"",
    "test:integration": "tsx --test \"tests/integration/**/*.test.ts\"",
    "test:golden": "tsx --test \"tests/golden/**/*.test.ts\"",
    "test:versioning": "tsx --test \"tests/versioning/**/*.test.ts\"",
    "test:matrix": "tsx --test \"tests/matrix/**/*.test.ts\"",
    "test:e2e": "tsx --test \"tests/e2e/**/*.test.ts\"",
    "smoke:headless": "tsx src/apps/cli/src/index.ts run \"smoke\" --output jsonl",
    "smoke:live:deepseek": "tsx --test \"tests/live/deepseek-provider-live-smoke.test.ts\"",
    "smoke:live:agent-loop": "tsx --test \"tests/live/deepseek-agent-loop-live-smoke.test.ts\"",
    "smoke:live:agent-tools": "tsx --test \"tests/live/deepseek-agent-tool-live-smoke.test.ts\"",
    "acceptance:index": "node scripts/write-acceptance-index.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
